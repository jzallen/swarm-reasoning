# =============================================================================
# swarm-reasoning — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values.
# =============================================================================

# ---------------------------------------------------------------------------
# Required — API keys for agent service LLM and fact-checking integrations
# ---------------------------------------------------------------------------

ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_FACTCHECK_API_KEY=your-google-factcheck-api-key
NEWSAPI_KEY=your-newsapi-key

# ---------------------------------------------------------------------------
# Optional — Defaults are set for local Docker Compose development
# ---------------------------------------------------------------------------

DATABASE_URL=postgresql://swarm:swarm@postgresql:5432/swarm
REDIS_URL=redis://redis:6379
TEMPORAL_ADDRESS=temporal:7233
SNAPSHOT_STORE=local
S3_BUCKET_NAME=
AWS_REGION=us-east-1
CLOUDFRONT_DOMAIN=
NODE_ENV=development
