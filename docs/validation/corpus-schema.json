{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PolitiFact Validation Corpus",
  "description": "50-claim PolitiFact corpus for swarm-reasoning accuracy validation",
  "type": "object",
  "required": ["version", "claims"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "claims": {
      "type": "array",
      "minItems": 50,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": [
          "id",
          "claim_text",
          "ground_truth",
          "categories",
          "politifact_url",
          "captured_date",
          "speaker",
          "domain"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^pf-\\d{4}-\\d{3}$"
          },
          "claim_text": {
            "type": "string",
            "minLength": 10
          },
          "ground_truth": {
            "type": "string",
            "enum": [
              "TRUE",
              "MOSTLY_TRUE",
              "HALF_TRUE",
              "MOSTLY_FALSE",
              "FALSE",
              "PANTS_FIRE"
            ]
          },
          "categories": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "TRUE_MOSTLY_TRUE",
                "FALSE_PANTS_FIRE",
                "HALF_TRUE",
                "CLAIMREVIEW_INDEXED",
                "NOT_CLAIMREVIEW_INDEXED"
              ]
            }
          },
          "politifact_url": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://www\\.politifact\\.com/"
          },
          "captured_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "speaker": {
            "type": "string",
            "minLength": 1
          },
          "domain": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
