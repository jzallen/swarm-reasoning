---
title: Agent Topology — swarm-reasoning
---
graph TD

  %% ============================================================
  %% Legend
  %% ============================================================

  subgraph LEGEND["Legend"]
    direction LR
    L1["─── MCP control plane"]
    L2["··· Redis Streams data plane"]
  end

  %% ============================================================
  %% Claim entry point
  %% ============================================================

  CLAIM_IN(["Claim submitted\nHTTP POST"])

  %% ============================================================
  %% Phase 1 — Sequential ingestion
  %% ============================================================

  subgraph PHASE1["Phase 1 — Sequential"]
    A1["① Ingestion Agent\n───────────────\nClaim registration\nPublishes CLAIM_TEXT\nCLAIM_SOURCE_*\nCLAIM_DOMAIN"]
    A2["② Claim Detector\n───────────────\nCheck-worthiness score\nClaim normalisation\nPublishes CHECK_WORTHY\nCLAIM_NORMALIZED"]
    A3["③ Entity Extractor\n───────────────\nNER extraction\nPersons · Orgs\nDates · Locations\nStatistics"]
  end

  %% ============================================================
  %% Phase 2 — Parallel fan-out
  %% ============================================================

  subgraph PHASE2["Phase 2 — Parallel Fan-Out"]
    direction LR
    A4["④ ClaimReview\nMatcher\n───────────────\nGoogle Fact Check\nTools API\nSemantic match"]
    A5["⑤ Coverage\nAgent — Left\n───────────────\nLeft-spectrum\narticle analysis\nFraming"]
    A6["⑥ Coverage\nAgent — Center\n───────────────\nCenter-spectrum\narticle analysis\nFraming"]
    A7["⑦ Coverage\nAgent — Right\n───────────────\nRight-spectrum\narticle analysis\nFraming"]
    A9["⑧ Domain\nEvidence Agent\n───────────────\nCDC · SEC · WHO\nCourt records\nPrimary alignment"]
  end

  %% ============================================================
  %% Phase 3 — Aggregation
  %% ============================================================

  subgraph PHASE3["Phase 3 — Aggregation"]
    direction LR
    A8["⑨ Blindspot\nDetector\n───────────────\nReads ⑤ ⑥ ⑦\nCoverage asymmetry\nCross-spectrum check"]
    A10["⑩ Synthesizer\n───────────────\nReads full obs log\nResolves F/C entries\nConfidence score\nVerdict emission"]
  end

  %% ============================================================
  %% Output
  %% ============================================================

  CONSUMER(["Consumer API\nJSON verdict\n+ audit trail"])

  %% ============================================================
  %% MCP control plane edges (solid)
  %% ============================================================

  CLAIM_IN -->|"HTTP"| A1
  A1 -->|"MCP: orchestrator dispatches"| A2
  A2 -->|"MCP: orchestrator dispatches"| A3
  A3 -->|"MCP: orchestrator fans out"| A4
  A3 -->|"MCP: orchestrator fans out"| A5
  A3 -->|"MCP: orchestrator fans out"| A6
  A3 -->|"MCP: orchestrator fans out"| A7
  A3 -->|"MCP: orchestrator fans out"| A9
  A5 -->|"MCP: orchestrator gates ⑨\nafter ⑤⑥⑦ complete"| A8
  A6 --> A8
  A7 --> A8
  A4 -->|"MCP: orchestrator gates ⑩\nafter all parallel complete"| A10
  A8 --> A10
  A9 --> A10
  A10 -->|"JSON via API"| CONSUMER

  %% ============================================================
  %% Cancellation path
  %% ============================================================

  A2 -->|"check_worthy < 0.4\nrun CANCELLED"| CANCEL(["Run cancelled\nstatus X"])

  %% ============================================================
  %% Observation stream annotations
  %% ============================================================

  A1 -.->|"publishes START + OBS"| LOG[("Append-only\nObservation Streams\nRedis Streams")]
  A2 -.->|"publishes obs P→F"| LOG
  A3 -.->|"publishes obs P→F"| LOG
  A4 -.->|"publishes obs P→F"| LOG
  A5 -.->|"publishes obs P→F"| LOG
  A6 -.->|"publishes obs P→F"| LOG
  A7 -.->|"publishes obs P→F"| LOG
  A8 -.->|"publishes obs P→F\nmay emit C corrections"| LOG
  A9 -.->|"publishes obs P→F"| LOG
  A10 -.->|"publishes VERDICT\nCONFIDENCE_SCORE\nVERDICT_NARRATIVE F"| LOG

  %% ============================================================
  %% Styling
  %% ============================================================

  classDef agent fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f,rx:6
  classDef io fill:#fff7ed,stroke:#ea580c,color:#431407
  classDef store fill:#fef9c3,stroke:#ca8a04,color:#713f12
  classDef cancel fill:#fee2e2,stroke:#dc2626,color:#7f1d1d

  class A1,A2,A3,A4,A5,A6,A7,A8,A9,A10 agent
  class CLAIM_IN,CONSUMER io
  class LOG store
  class CANCEL cancel
