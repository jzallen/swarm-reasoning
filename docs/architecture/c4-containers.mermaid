  %% ============================================================
  %% Redis Streams Data Plane
  %% ============================================================

  INGEST -->|"XADD observations"| REDIS
  DETECT -->|"XADD observations"| REDIS
  ENTITY -->|"XADD observations"| REDIS
  CR -->|"XADD observations"| REDIS
  COV_L -->|"XADD observations"| REDIS
  COV_C -->|"XADD observations"| REDIS
  COV_R -->|"XADD observations"| REDIS
  DOM -->|"XADD observations"| REDIS
  BLIND -->|"XADD observations"| REDIS
  SYNTH -->|"XADD observations"| REDIS

  ORCH -->|"XREADGROUP\nconsume all streams"| REDIS
  CAPI -->|"XRANGE\nread finalized obs"| REDIS

  %% ============================================================
  %% External API calls
  %% ============================================================

  CR -->|"HTTPS ClaimReview query"| GFCT
  COV_L -->|"HTTPS article retrieval"| NEWSAPI
  COV_C -->|"HTTPS article retrieval"| NEWSAPI
  COV_R -->|"HTTPS article retrieval"| NEWSAPI
  DOM -->|"HTTPS primary source fetch"| PRIMARY

  %% ============================================================
  %% Consumer-facing
  %% ============================================================

  CAPI -->|"JSON REST API"| DASHBOARD

