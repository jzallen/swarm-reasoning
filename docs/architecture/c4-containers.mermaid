  class NEWSAPI,GFCT,MBFC,PRIMARY external
  class INGEST,DETECT,ENTITY,CR,COV_L,COV_C,COV_R,DOM,BLIND,SYNTH agent
  class INGEST_YDB,DETECT_YDB,ENTITY_YDB,CR_YDB,COV_L_YDB,COV_C_YDB,COV_R_YDB,DOM_YDB,BLIND_YDB,SYNTH_YDB ydb
  class INGEST_MIRTH,DETECT_MIRTH,ENTITY_MIRTH,CR_MIRTH,COV_L_MIRTH,COV_C_MIRTH,COV_R_MIRTH,DOM_MIRTH,BLIND_MIRTH,SYNTH_MIRTH,ORCH_MIRTH mirth
  class ORCH orch
  class DASHBOARD consumer
