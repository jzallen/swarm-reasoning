---
title: C4 Container Diagram — swarm-reasoning
---
graph TB

  %% ============================================================
  %% External Systems
  %% ============================================================

  subgraph EXT["External Systems"]
    direction TB
    NEWSAPI["NewsAPI / GNews\n─────────────\nArticle retrieval\nREST API"]
    GFCT["Google Fact Check Tools API\n─────────────\nClaimReview index\nREST API"]
    MBFC["Media Bias Fact Check\n─────────────\nSource credibility ratings\nWeb / CSV"]
    PRIMARY["Primary Sources\n─────────────\nCDC · SEC · WHO\nCourt records\nHTTPS"]
  end

  %% ============================================================
  %% User / Browser
  %% ============================================================

  subgraph USER_ZONE["User Boundary"]
    USER["User / Browser\n─────────────\nReact SPA\nReceives SSE progress"]
  end

  %% ============================================================
  %% Edge / CDN
  %% ============================================================

  subgraph EDGE["Edge Layer"]
    direction LR
    CF["Cloudflare\n─────────────\nEdge proxy\nDDoS protection\nTLS termination"]
    CLOUDFRONT["CloudFront + S3\n─────────────\nFrontend static build\n(React/Vite)\nHTML snapshots"]
  end

  %% ============================================================
  %% AWS Load Balancer
  %% ============================================================

  ALB["Application Load Balancer\n─────────────\nAWS ALB\nRoute to ECS tasks"]

  %% ============================================================
  %% Backend API
  %% ============================================================

  subgraph BACKEND_SVC["Backend API  [ECS Fargate]"]
    BACKEND["NestJS Backend\n─────────────\nClean Architecture\nTypeORM\nREST + SSE endpoints\nTypeScript / Node 20"]
  end

  %% ============================================================
  %% Temporal Server
  %% ============================================================

  TEMPORAL["Temporal Server\n─────────────\nWorkflow orchestration\nActivity dispatch\nRetry policies\nPhase gating"]

  %% ============================================================
  %% Data Stores
  %% ============================================================

  POSTGRES[("PostgreSQL\n─────────────\nAurora Serverless v2\nClaims, runs, verdicts\nTypeORM entities")]
  REDIS[("Redis\n─────────────\nElastiCache\nRedis Streams\nObservation log\nProgress streams\nConsumer groups")]
  S3_DATA[("S3\n─────────────\nStatic HTML snapshots\nVerdict archives")]

  %% ============================================================
  %% Agent Service — Sequential Phase
  %% ============================================================

  subgraph AGENT_SVC["Agent Service  [ECS Fargate — Temporal Workers]"]
    direction TB

    subgraph SEQ_PHASE["Phase 1 — Sequential  [Agents 1–3]"]
      direction LR
      INGEST["Ingestion Agent\n─────────────\nAccepts raw claim\nPublishes observations\nPython / LangChain"]
      DETECT["Claim Detector\n─────────────\nCheck-worthiness scoring\nClaim normalisation\nPython / LangChain"]
      ENTITY["Entity Extractor\n─────────────\nNER: persons orgs\ndates locations\nstatistics\nPython / LangChain"]
    end

    %% ============================================================
    %% Agent Service — Parallel Phase
    %% ============================================================

    subgraph PAR_PHASE["Phase 2 — Parallel  [Agents 4–9]"]
      direction LR
      CR["ClaimReview Matcher\n─────────────\nGoogle Fact Check Tools\nSemantic matching\nPython / LangChain"]
      COV_L["Coverage Agent — Left\n─────────────\nLeft-spectrum sources\nFraming analysis"]
      COV_C["Coverage Agent — Center\n─────────────\nCenter-spectrum sources\nFraming analysis"]
      COV_R["Coverage Agent — Right\n─────────────\nRight-spectrum sources\nFraming analysis"]
      DOM["Domain Evidence Agent\n─────────────\nCDC · SEC · WHO\nPrimary source alignment"]
      SRC_VAL["Source Validator\n─────────────\nLink extraction\nURL validation\nSource convergence\nCitation aggregation"]
    end

    %% ============================================================
    %% Agent Service — Aggregation Phase
    %% ============================================================

    subgraph AGG_PHASE["Phase 3 — Aggregation  [Agents 10–11]"]
      direction LR
      BLIND["Blindspot Detector\n─────────────\nReads coverage streams\nComputes asymmetry\nFlags absent spectrum"]
      SYNTH["Synthesizer Agent\n─────────────\nReads full observation log\nResolves F/C entries\nEmits VERDICT\nCONFIDENCE_SCORE"]
    end
  end

  %% ============================================================
  %% User → Edge → Backend
  %% ============================================================

  USER -->|"HTTPS"| CF
  CF -->|"API requests"| ALB
  ALB -->|"HTTP"| BACKEND
  USER -->|"HTTPS static"| CLOUDFRONT

  %% ============================================================
  %% Backend → Data Stores
  %% ============================================================

  BACKEND -->|"TypeORM\nCRUD operations"| POSTGRES
  BACKEND -->|"XRANGE / subscribe\nprogress:{runId}\nSSE relay"| REDIS
  BACKEND -->|"store/serve\nHTML snapshots"| S3_DATA

  %% ============================================================
  %% Backend → Temporal (start workflows)
  %% ============================================================

  BACKEND -->|"start workflow\nfact-check run"| TEMPORAL

  %% ============================================================
  %% Temporal → Agent Service (dispatch activities)
  %% ============================================================

  TEMPORAL -->|"dispatch activities\nphase gating"| INGEST
  TEMPORAL -->|"dispatch activities"| DETECT
  TEMPORAL -->|"dispatch activities"| ENTITY
  TEMPORAL -->|"dispatch activities"| CR
  TEMPORAL -->|"dispatch activities"| COV_L
  TEMPORAL -->|"dispatch activities"| COV_C
  TEMPORAL -->|"dispatch activities"| COV_R
  TEMPORAL -->|"dispatch activities"| DOM
  TEMPORAL -->|"dispatch activities"| SRC_VAL
  TEMPORAL -->|"dispatch activities"| BLIND
  TEMPORAL -->|"dispatch activities"| SYNTH

  %% ============================================================
  %% Redis Streams Data Plane
  %% ============================================================

  INGEST -->|"XADD observations"| REDIS
  DETECT -->|"XADD observations"| REDIS
  ENTITY -->|"XADD observations"| REDIS
  CR -->|"XADD observations"| REDIS
  COV_L -->|"XADD observations"| REDIS
  COV_C -->|"XADD observations"| REDIS
  COV_R -->|"XADD observations"| REDIS
  DOM -->|"XADD observations"| REDIS
  SRC_VAL -->|"XADD observations"| REDIS
  BLIND -->|"XADD observations"| REDIS
  SYNTH -->|"XADD observations"| REDIS

  %% ============================================================
  %% External API calls
  %% ============================================================

  CR -->|"HTTPS ClaimReview query"| GFCT
  COV_L -->|"HTTPS article retrieval"| NEWSAPI
  COV_C -->|"HTTPS article retrieval"| NEWSAPI
  COV_R -->|"HTTPS article retrieval"| NEWSAPI
  DOM -->|"HTTPS primary source fetch"| PRIMARY
  SRC_VAL -->|"HTTPS credibility lookup"| MBFC

  %% ============================================================
  %% SSE from Backend to User
  %% ============================================================

  BACKEND -->|"SSE\nprogress events"| USER

  %% ============================================================
  %% Styling
  %% ============================================================

  classDef external fill:#f5f5f5,stroke:#999,color:#333
  classDef agent fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f
  classDef redis fill:#fef9c3,stroke:#ca8a04,color:#713f12
  classDef temporal fill:#ede9fe,stroke:#7c3aed,color:#2e1065
  classDef consumer fill:#fff7ed,stroke:#ea580c,color:#431407
  classDef backend fill:#f0fdf4,stroke:#86efac,color:#14532d
  classDef edge fill:#fef3c7,stroke:#f59e0b,color:#78350f
  classDef store fill:#fef9c3,stroke:#ca8a04,color:#713f12

  class NEWSAPI,GFCT,MBFC,PRIMARY external
  class INGEST,DETECT,ENTITY,CR,COV_L,COV_C,COV_R,DOM,SRC_VAL,BLIND,SYNTH agent
  class REDIS,POSTGRES,S3_DATA store
  class TEMPORAL temporal
  class USER consumer
  class BACKEND backend
  class CF,CLOUDFRONT,ALB edge
