  ORCH -.->|"MCP tool calls"| CR
  ORCH -.->|"MCP tool calls"| COV_L
  ORCH -.->|"MCP tool calls"| COV_C
  ORCH -.->|"MCP tool calls"| COV_R
  ORCH -.->|"MCP tool calls"| DOM
