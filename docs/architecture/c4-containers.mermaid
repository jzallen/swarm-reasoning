  COV_C_MIRTH -->|"ACK + ORU^R01"| ORCH_MIRTH
  COV_R_MIRTH -->|"ACK + ORU^R01"| ORCH_MIRTH
  DOM_MIRTH -->|"ACK + ORU^R01"| ORCH_MIRTH
