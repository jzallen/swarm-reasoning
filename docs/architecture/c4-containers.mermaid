      DETECT_MIRTH["Mirth\nPort 6663"]
    end

    subgraph ENTITY_B["Entity Extractor Bundle"]
      ENTITY["Entity Extractor\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nNER: persons orgs\ndates locations\nstatistics\nPython / LangChain"]
