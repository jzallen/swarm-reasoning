  %% ============================================================
  %% Agent Bundles вЂ” Sequential Phase
  %% ============================================================

  subgraph SEQ_PHASE["Sequential Phase  [Agents 1вЂ“3]"]
    direction LR

    subgraph INGEST_B["Ingestion Bundle"]
      INGEST["Ingestion Agent\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nAccepts raw claim\nEmits MSH + PID\nPython / LangChain"]
      INGEST_YDB["YottaDB\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n^CLAIM ^MSG\n^RUN globals"]
