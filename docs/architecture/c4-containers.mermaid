      COV_R_YDB["YottaDB\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCOVERAGE_* codes\nOBX.16=coverage-right"]
