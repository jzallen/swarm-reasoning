---
title: Docker Topology — swarm-reasoning
---
flowchart TD

    subgraph HOST["Host Machine"]
        BROWSER["User Browser"]
    end

    subgraph SWARM_NET["swarm-net (Docker bridge network)"]

        subgraph APP_FRONTEND["Frontend (React/TypeScript, Vite)"]
            FE["frontend\n:5173"]
        end

        subgraph APP_BACKEND["Backend API (NestJS)"]
            BE["backend\n:3000"]
        end

        subgraph APP_AGENTS["Agent Service (Python/LangChain)"]
            AS["agent-service\n11 Temporal workers\n(one per agent type)"]
        end

        subgraph TEMPORAL_STACK["Temporal"]
            TS["temporal\n:7233\n(auto-setup)"]
            TUI["temporal-ui\n:8233"]
            TDB["temporal-db\n:5433 -> 5432\n(postgres:16)"]
        end

        subgraph DATA["Data Stores"]
            PG["postgresql\n:5432\ndb: swarm"]
            REDIS["redis\n:6379\nRedis Streams\n(observations + progress)"]
        end

        %% Frontend to Backend
        FE -->|"API calls + SSE"| BE

        %% Backend connections
        BE -->|"queries"| PG
        BE -->|"read streams"| REDIS
        BE -->|"start workflows"| TS

        %% Temporal Server connections
        TS -->|"state store"| TDB
        TS -->|"dispatch activities"| AS

        %% Temporal UI
        TUI -->|"gRPC"| TS

        %% Agent Service connections
        AS -->|"publish observations\n+ progress"| REDIS
        AS -->|"External APIs\n(Google Fact Check,\nNewsAPI, Anthropic)"| EXTERNAL

    end

    EXTERNAL["External APIs"]

    %% Host to containers (port mappings)
    BROWSER -->|":5173"| FE
    BROWSER -->|":3000"| BE
    BROWSER -->|":8233"| TUI

    %% Startup dependency order
    note1["Startup order:\n1. PostgreSQL, Temporal DB, Redis\n2. Temporal Server\n3. Agent Service, Backend\n4. Temporal UI, Frontend\n\n8 containers total"]

    classDef frontend fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f
    classDef backend fill:#f0fdf4,stroke:#86efac,color:#14532d
    classDef agents fill:#fce7f3,stroke:#ec4899,color:#831843
    classDef temporal fill:#e0e7ff,stroke:#6366f1,color:#312e81
    classDef datastore fill:#fef9c3,stroke:#ca8a04,color:#713f12
    classDef external fill:#f1f5f9,stroke:#94a3b8,color:#334155
    classDef note fill:#fefce8,stroke:#fde047,color:#713f12

    class FE frontend
    class BE backend
    class AS agents
    class TS,TUI,TDB temporal
    class PG,REDIS datastore
    class EXTERNAL external
    class note1 note
