---
title: Data Flow Diagram вЂ” Trust Boundaries вЂ” swarm-reasoning
---
flowchart TD

  %% ============================================================
  %% Trust Zone: Public Internet
  %% ============================================================

  subgraph INTERNET["Public Internet  [untrusted]"]
    direction LR
    USER(["Analyst / API Client\nSubmits claim URL\nor claim text"])
    NEWSAPI_EXT["NewsAPI / GNews\nArticle content\nPublicly licensed"]
    GFCT_EXT["Google Fact Check\nTools API\nClaimReview index"]
    PRIMARY_EXT["CDC В· SEC В· WHO\nCourt records\nAuthoritative public data"]
  end

  %% ============================================================
  %% Trust Zone: DMZ вЂ” API Gateway
  %% ============================================================

  subgraph DMZ["DMZ  [semi-trusted вЂ” TLS termination + rate limiting]"]
    GATEWAY["API Gateway\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nTLS termination\nRate limiting\nClaim text sanitisation\nPII scrubbing before ingestion"]
  end

  %% ============================================================
  %% Trust Zone: Internal Agent Mesh
  %% ============================================================

  subgraph INTERNAL["Internal Agent Mesh  [trusted вЂ” Docker internal network]"]
    direction TB

    subgraph ORCH_ZONE["Orchestrator Zone"]
      ORCH_PROC["Orchestrator\nMCP client hub\nDAG manager\nStream consumer"]
    end

    subgraph AGENT_ZONE["Agent Zone"]
      direction LR
      AG_SEQ["Sequential agents\n1. Ingestion\n2. Claim Detector\n3. Entity Extractor"]
      AG_PAR["Parallel agents\n4. ClaimReview\n5-7. Coverage L/C/R\n8. Domain Evidence"]
      AG_AGG["Aggregation agents\n9. Blindspot Detector\n10. Synthesizer"]
    end

    subgraph DATA_ZONE["Data Zone"]
      REDIS_STORE[("Redis\nAppend-only\nObservation Streams\nreasoning:runId:agent")]
    end
  end

  %% ============================================================
  %% Trust Zone: Consumer
  %% ============================================================

  subgraph CONSUMER_ZONE["Consumer Zone  [semi-trusted вЂ” authenticated read-only]"]
    DASHBOARD_PROC["Verdict Dashboard\nJSON REST consumer\nRead-only access"]
  end

  %% ============================================================
  %% Data flows with sensitivity labels
  %% ============================================================

  USER -->|"HTTPS POST\nclaim_text or url\n[PUBLIC DATA]"| GATEWAY
  GATEWAY -->|"sanitised claim\nPII scrubbed\n[INTERNAL]"| ORCH_PROC

  ORCH_PROC -.->|"MCP tool calls\n[INTERNAL CONTROL]"| AG_SEQ
  ORCH_PROC -.->|"MCP tool calls\n[INTERNAL CONTROL]"| AG_PAR
  ORCH_PROC -.->|"MCP tool calls\n[INTERNAL CONTROL]"| AG_AGG

  AG_SEQ -->|"XADD observations\n[INTERNAL DATA]"| REDIS_STORE
  AG_PAR -->|"XADD observations\n[INTERNAL DATA]"| REDIS_STORE
  AG_AGG -->|"XADD observations\n[INTERNAL DATA]"| REDIS_STORE

  ORCH_PROC -->|"XREADGROUP\nconsume observations\n[INTERNAL DATA]"| REDIS_STORE

  AG_PAR -->|"HTTPS\narticle retrieval\n[PUBLIC DATA]"| NEWSAPI_EXT
  AG_PAR -->|"HTTPS\nClaimReview query\n[PUBLIC DATA]"| GFCT_EXT
  AG_PAR -->|"HTTPS\nprimary source fetch\n[PUBLIC DATA]"| PRIMARY_EXT

  REDIS_STORE -->|"XRANGE\nfinalized observations\n[INTERNAL вЂ” read-only export]"| DASHBOARD_PROC

  %% ============================================================
  %% Trust boundary crossing annotations
  %% ============================================================

  TB1["BOUNDARY CROSSING RULES\nв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\nInternet в†’ DMZ:\n  TLS required В· rate limited\n  claim text sanitised\n  no raw URLs passed to agents\n\nDMZ в†’ Internal:\n  PII scrubbed before ingestion\n  claim_id assigned at gateway\n  original URL stored, not forwarded\n\nInternal в†’ External APIs:\n  no claim_id or internal IDs sent\n  only normalised claim text or\n  entity strings used as query params\n  API keys in Docker secrets\n\nInternal в†’ Consumer:\n  read-only JSON export via API\n  no Redis keys exposed directly\n  audit trail included in payload"]

  %% ============================================================
  %% Data classification legend
  %% ============================================================

  DC["DATA CLASSIFICATION\nв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\n[PUBLIC DATA]     Sourced from public web\n[INTERNAL]        Claim text post-sanitisation\n[INTERNAL DATA]   JSON observation stream entries\n[INTERNAL CONTROL] MCP tool calls + responses\n[INTERNAL вЂ” read-only export] Final verdict JSON"]

  %% ============================================================
  %% Styling
  %% ============================================================

  classDef untrusted fill:#fef2f2,stroke:#ef4444,color:#7f1d1d
  classDef dmz fill:#fff7ed,stroke:#f97316,color:#431407
  classDef internal fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f
  classDef consumer fill:#f0fdf4,stroke:#22c55e,color:#14532d
  classDef store fill:#fef9c3,stroke:#ca8a04,color:#713f12
  classDef note fill:#fafafa,stroke:#d1d5db,color:#374151

  class USER,NEWSAPI_EXT,GFCT_EXT,PRIMARY_EXT untrusted
  class GATEWAY dmz
  class ORCH_PROC,AG_SEQ,AG_PAR,AG_AGG internal
  class REDIS_STORE store
  class DASHBOARD_PROC consumer
  class TB1,DC note
