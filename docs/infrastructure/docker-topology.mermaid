---
title: Docker Topology — swarm-reasoning
---
flowchart TD

    subgraph HOST["Host Machine"]
        BROWSER["Browser / curl\n(developer)"]
    end

    subgraph EXTERNAL_NET["external network (bridge)"]
        PORT8000["host:8000"]
        PORT6379["host:6379\n(Redis — dev only)"]
    end

    subgraph INTERNAL_NET["internal network (bridge) — not reachable from host"]

        subgraph DATA["Data Plane"]
            REDIS["redis\n:6379\nRedis Streams\nAppend-only observation log"]
        end

        subgraph ORCH["Orchestrator"]
            ORC["orchestrator\n:8080 (health)\n:9000 (MCP client hub)\nXREADGROUP consumer"]
        end

        subgraph API_SVC["Consumer API"]
            CAPI["consumer-api\n:8000\nXRANGE reader"]
        end

        ORC --> REDIS
        CAPI --> REDIS
        CAPI --> ORC

        subgraph ING["Ingestion Agent"]
            ING_A["ingestion-agent\n:9001 (MCP server)"]
        end

        subgraph DET["Claim Detector"]
            DET_A["claim-detector\n:9002 (MCP server)"]
        end

        subgraph ENT["Entity Extractor"]
            ENT_A["entity-extractor\n:9003 (MCP server)"]
        end

        subgraph CR["ClaimReview Matcher"]
            CR_A["claimreview-matcher\n:9004 (MCP server)"]
        end

        subgraph CL["Coverage Left"]
            CL_A["coverage-left\n:9005 (MCP server)"]
        end

        subgraph CC["Coverage Center"]
            CC_A["coverage-center\n:9006 (MCP server)"]
        end

        subgraph CRR["Coverage Right"]
            CRR_A["coverage-right\n:9007 (MCP server)"]
        end

        subgraph BS["Blindspot Detector"]
            BS_A["blindspot-detector\n:9008 (MCP server)"]
        end

        subgraph DE["Domain Evidence"]
            DE_A["domain-evidence\n:9009 (MCP server)"]
        end

        subgraph SY["Synthesizer"]
            SY_A["synthesizer\n:9010 (MCP server)"]
        end

        %% MCP connections — orchestrator to each agent (control plane)
        ORC -.->|"MCP :9001"| ING_A
        ORC -.->|"MCP :9002"| DET_A
        ORC -.->|"MCP :9003"| ENT_A
        ORC -.->|"MCP :9004"| CR_A
        ORC -.->|"MCP :9005"| CL_A
        ORC -.->|"MCP :9006"| CC_A
        ORC -.->|"MCP :9007"| CRR_A
        ORC -.->|"MCP :9008"| BS_A
        ORC -.->|"MCP :9009"| DE_A
        ORC -.->|"MCP :9010"| SY_A

        %% Redis Streams — all agents publish to Redis (data plane)
        ING_A -->|"XADD"| REDIS
        DET_A -->|"XADD"| REDIS
        ENT_A -->|"XADD"| REDIS
        CR_A -->|"XADD"| REDIS
        CL_A -->|"XADD"| REDIS
        CC_A -->|"XADD"| REDIS
        CRR_A -->|"XADD"| REDIS
        BS_A -->|"XADD"| REDIS
        DE_A -->|"XADD"| REDIS
        SY_A -->|"XADD"| REDIS

    end

    %% External port bindings
    BROWSER -->|"HTTP :8000"| PORT8000
    PORT8000 --> CAPI
    PORT6379 --> REDIS

    %% Startup dependency order
    note1["Startup order:\n1. Redis\n2. All agent processes\n3. Orchestrator\n4. Consumer API\n\n13 containers total\n(down from 33)"]

    classDef agent fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f
    classDef redis fill:#fef9c3,stroke:#ca8a04,color:#713f12
    classDef orch fill:#fce7f3,stroke:#ec4899,color:#831843
    classDef api fill:#f0fdf4,stroke:#86efac,color:#14532d
    classDef note fill:#fefce8,stroke:#fde047,color:#713f12

    class ING_A,DET_A,ENT_A,CR_A,CL_A,CC_A,CRR_A,BS_A,DE_A,SY_A agent
    class REDIS redis
    class ORC orch
    class CAPI api
    class note1 note
